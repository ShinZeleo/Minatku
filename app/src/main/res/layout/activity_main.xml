<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient">


    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-40dp"
        android:background="@drawable/bg_icon_circle"
        android:alpha="0.3" />


    <View
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="-30dp"
        android:layout_marginStart="-30dp"
        android:background="@drawable/bg_icon_circle"
        android:alpha="0.2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_centerInParent="true"
        android:paddingHorizontal="32dp">


        <com.airbnb.lottie.LottieAnimationView
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            app:lottie_rawRes="@raw/splash_animation"
            app:lottie_autoPlay="true"
            app:lottie_loop="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MinatKu"
            android:textSize="36sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:letterSpacing="0.02"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sistem Personalisasi Minat &amp; Hobi Mahasiswa"
            android:textSize="14sp"
            android:textColor="#C7D2FE"
            android:textAlignment="center"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvDataCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Memuat data..."
            android:textSize="12sp"
            android:textColor="#A5B4FC"
            android:textAlignment="center"
            android:layout_marginBottom="36dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_glass_card"
            android:padding="24dp">

            <TextView
                android:id="@+id/btnInputData"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_btn_primary_pill"
                android:text="📝  Input Data Baru"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/btnLihatData"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_btn_secondary_pill"
                android:text="📊  Lihat Dashboard"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H071241048 - Imam Dzaqhoir"
            android:textSize="11sp"
            android:textColor="#8B9CF7"
            android:layout_marginTop="32dp" />

    </LinearLayout>

</RelativeLayout>
